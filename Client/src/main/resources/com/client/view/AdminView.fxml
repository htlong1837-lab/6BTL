<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="600.0" prefWidth="900.0"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.AdminController">
   <top>
      <HBox prefHeight="50.0" prefWidth="200.0" style="-fx-spacing: 10; -fx-padding: 12 16;" BorderPane.alignment="CENTER">
         <children>
            <Label text="Admin Dashboard" />
            <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
            <Button mnemonicParsing="false" onAction="#handleLogout" text="Đăng xuất" />
         </children>
      </HBox>
   </top>
   <center>
      <VBox prefWidth="100.0" style="-fx-spacing: 16; -fx-padding: 16;" BorderPane.alignment="CENTER">
         <children>
            <!-- Thống kê -->
            <HBox prefHeight="80.0" prefWidth="200.0" style="-fx-spacing: 12;">
               <children>
                  <VBox alignment="CENTER" prefWidth="100.0" style="-fx-spacing: 6; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="totalProductsLabel" text="0" />
                        <Label text="Sản phẩm" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="100.0" style="-fx-spacing: 6; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="totalBidsLabel" text="0" />
                        <Label text="Lượt đấu giá" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="100.0" style="-fx-spacing: 6; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="totalUsersLabel" text="0" />
                        <Label text="Người dùng" />
                     </children>
                  </VBox>
                  <VBox alignment="CENTER" prefWidth="100.0" style="-fx-spacing: 6; -fx-padding: 16;" HBox.hgrow="ALWAYS">
                     <children>
                        <Label fx:id="totalAuctionsLabel" text="0" />
                        <Label text="Phiên đang chạy" />
                     </children>
                  </VBox>
               </children>
            </HBox>
            <!-- Tìm kiếm -->
            <HBox prefHeight="36.0" prefWidth="200.0">
               <children>
                  <TextField fx:id="searchUserField" promptText="Tìm người dùng" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleSearchUser" text="Tìm" />
               </children>
            </HBox>
            <!-- Bảng người dùng -->
            <TableView fx:id="userTable" prefHeight="340.0" prefWidth="200.0" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colUserId"     prefWidth="80.0"  text="ID" />
                  <TableColumn fx:id="colUsername"   prefWidth="160.0" text="Tên đăng nhập" />
                  <TableColumn fx:id="colEmail"      prefWidth="200.0" text="Email" />
                  <TableColumn fx:id="colRole"       prefWidth="100.0" text="Vai trò" />
                  <TableColumn fx:id="colUserStatus" prefWidth="120.0" text="Trạng thái" />
               </columns>
            </TableView>
            <!-- Thanh trạng thái + nút hành động -->
            <HBox prefHeight="36.0" prefWidth="200.0" style="-fx-spacing: 10;">
               <children>
                  <Label fx:id="userStatusLabel" text="0 người dùng" />
                  <Region prefHeight="200.0" prefWidth="200.0" HBox.hgrow="ALWAYS" />
                  <Button mnemonicParsing="false" onAction="#handleBan"   text="BAN" />
                  <Button mnemonicParsing="false" onAction="#handleUnban" text="UNBAN" />
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
