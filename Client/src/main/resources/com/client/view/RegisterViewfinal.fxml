<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="700.0" prefWidth="750.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e3a5f);"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.RegisterController">
   <children>
      <VBox alignment="CENTER" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
            AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>

            <!-- Header -->
            <VBox alignment="CENTER" spacing="4">
               <Label text="⚡ HỆ THỐNG ĐẤU GIÁ"
                      style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #f59e0b; -fx-letter-spacing: 2;"/>
               <Label text="Tạo tài khoản mới"
                      style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: white;"/>
               <Label text="Điền thông tin bên dưới để bắt đầu"
                      style="-fx-font-size: 13; -fx-text-fill: #94a3b8;"/>
            </VBox>

            <Region prefHeight="20"/>

            <!-- Form card -->
            <VBox alignment="TOP_CENTER" maxWidth="460.0" prefWidth="460.0" spacing="13.0"
                  style="-fx-background-color: white;
                         -fx-background-radius: 16;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.35), 30, 0, 0, 8);
                         -fx-padding: 40 44 40 44;">
               <children>

                  <!-- Tên đăng nhập -->
                  <VBox spacing="5">
                     <Label text="Tên đăng nhập *"
                            style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                     <TextField fx:id="userNameField" maxWidth="Infinity" prefHeight="42"
                        promptText="Nhập tên đăng nhập"
                        style="-fx-background-radius: 8; -fx-border-radius: 8;
                               -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                               -fx-padding: 10 14; -fx-font-size: 13;
                               -fx-background-color: #f8fafc;"/>
                  </VBox>

                  <!-- Mật khẩu -->
                  <VBox spacing="5">
                     <Label text="Mật khẩu *"
                            style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                     <PasswordField fx:id="passwordField" maxWidth="Infinity" prefHeight="42"
                        promptText="Tối thiểu 6 ký tự"
                        style="-fx-background-radius: 8; -fx-border-radius: 8;
                               -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                               -fx-padding: 10 14; -fx-font-size: 13;
                               -fx-background-color: #f8fafc;"/>
                  </VBox>

                  <!-- Xác nhận mật khẩu -->
                  <VBox spacing="5">
                     <Label text="Xác nhận mật khẩu *"
                            style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                     <PasswordField fx:id="confirmPasswordField" maxWidth="Infinity" prefHeight="42"
                        promptText="Nhập lại mật khẩu"
                        style="-fx-background-radius: 8; -fx-border-radius: 8;
                               -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                               -fx-padding: 10 14; -fx-font-size: 13;
                               -fx-background-color: #f8fafc;"/>
                  </VBox>

                  <!-- Vai trò -->
                  <VBox spacing="5">
                     <Label text="Vai trò *"
                            style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                     <ComboBox fx:id="roleComboBox" maxWidth="Infinity" prefHeight="42"
                        promptText="Chọn vai trò của bạn"
                        style="-fx-background-radius: 8; -fx-border-radius: 8;
                               -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                               -fx-padding: 4 10; -fx-font-size: 13;
                               -fx-background-color: #f8fafc;"/>
                  </VBox>

                  <!-- Error label -->
                  <Label fx:id="errorLabel" maxWidth="Infinity"
                         style="-fx-font-size: 12; -fx-text-fill: #dc2626;
                                -fx-background-color: #fef2f2; -fx-background-radius: 6;
                                -fx-padding: 8 12;"
                         visible="false" wrapText="true"/>

                  <Region prefHeight="4"/>

                  <!-- Nút đăng ký -->
                  <Button maxWidth="Infinity" prefHeight="46"
                     mnemonicParsing="false" onAction="#handleRegister"
                     style="-fx-background-radius: 8;
                            -fx-background-color: linear-gradient(to right, #1e3a5f, #2563eb);
                            -fx-text-fill: white; -fx-padding: 12;
                            -fx-font-size: 14; -fx-cursor: hand; -fx-font-weight: bold;"
                     text="TẠO TÀI KHOẢN →"/>

                  <!-- Link đăng nhập -->
                  <Label alignment="CENTER" maxWidth="Infinity"
                     onMouseClicked="#goToLogin"
                     style="-fx-text-fill: #2563eb; -fx-cursor: hand; -fx-font-size: 13;"
                     text="Đã có tài khoản? Đăng nhập ngay"
                     textAlignment="CENTER"/>

               </children>
            </VBox>

         </children>
      </VBox>
   </children>
</AnchorPane>
