<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane prefHeight="388.0" prefWidth="567.0" style="-fx-background-color: #f1f5f9;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.SellerController">
    <left>
        <VBox prefWidth="210" style="-fx-background-color: #0f172a; -fx-padding: 0; -fx-spacing: 0;">
            <VBox style="-fx-padding: 28 20 24 20; -fx-spacing: 4; -fx-background-color: #1e293b;">
                <Label style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #f59e0b;" text="ĐẤU GIÁ" />
                <Label fx:id="usernameLabel" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #f8fafc;" />
                <Label style="-fx-font-size: 11; -fx-text-fill: #94a3b8;" text="SELLER">
               <font>
                  <Font size="14.0" />
               </font></Label>
            </VBox>
            <Separator style="-fx-background-color: #334155;" />
            <VBox style="-fx-padding: 16 12; -fx-spacing: 6;" VBox.vgrow="ALWAYS">
                <Label style="-fx-font-size: 10; -fx-text-fill: #64748b; -fx-padding: 4 8 8 8; -fx-letter-spacing: 1;" text="QUẢN LÝ" />
                <Button maxWidth="Infinity" onAction="#showMyItems" prefHeight="40" style="-fx-background-color: #2563eb; -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 16; -fx-cursor: hand;" stylesheets="@style.css" text="📦  Sản phẩm của tôi" />
                <Button maxWidth="Infinity" onAction="#showAddItem" prefHeight="40" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 16; -fx-cursor: hand;" stylesheets="@style.css" text="➕  Thêm sản phẩm" />
                <Button maxWidth="Infinity" onAction="#showCreateAuction" prefHeight="40" style="-fx-background-color: transparent; -fx-text-fill: #94a3b8; -fx-font-size: 13; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 16; -fx-cursor: hand;" stylesheets="@style.css" text="🏷  Tạo phiên đấu giá" />
                <Region VBox.vgrow="ALWAYS" />
                <Separator style="-fx-background-color: #334155;" />
                <Button maxWidth="Infinity" onAction="#handleLogout" prefHeight="40" style="-fx-background-color: #7f1d1d; -fx-text-fill: #fca5a5; -fx-font-size: 13; -fx-background-radius: 8; -fx-alignment: CENTER_LEFT; -fx-padding: 0 16; -fx-cursor: hand;" text="🚪  Đăng xuất" />
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 28; -fx-background-color: #f1f5f9;" />
    </center>
</BorderPane>
