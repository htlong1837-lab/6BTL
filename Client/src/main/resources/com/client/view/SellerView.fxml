<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.SellerController">
    <left>
        <VBox style="-fx-padding: 20; -fx-spacing: 8;" prefWidth="190">
            <Label fx:id="usernameLabel" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Separator/>
            <Button text="Sản phẩm của tôi"   onAction="#showMyItems"      maxWidth="Infinity"
                    style=" -fx-text-fill: white;"/>
            <Button text="Thêm sản phẩm"       onAction="#showAddItem"      maxWidth="Infinity"
                    style="-fx-background-color: transparent; "/>
            <Button text="Tạo phiên đấu giá"   onAction="#showCreateAuction" maxWidth="Infinity"
                    style="-fx-background-color: transparent;"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Đăng xuất" onAction="#handleLogout" maxWidth="Infinity"/>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" style="-fx-padding: 20;"/>
    </center>
</BorderPane>
