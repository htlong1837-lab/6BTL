<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.Cursor?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.ToolBar?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.controller.SellerController">
    <left>
        <VBox prefWidth="190" style="-fx-padding: 20; -fx-background-color: #f0f8ff; -fx-spacing: 8; box-border-radius: 12;">
            <Label fx:id="usernameLabel" prefHeight="18.0" prefWidth="0.0" style="-fx-text-fill: black; -fx-font-weight: bold;" />
            <Separator />
            <Button maxWidth="Infinity" onAction="#showMyItems" style="-fx-text-fill: black; -fx-background-color: #fffaf0; -fx-border-color: #a9a9a9; -ex-text-fill: bold; efx-blend-mode: gray;" text="Sản phẩm của tôi">
            <cursor>
               <Cursor fx:constant="DEFAULT" />
            </cursor></Button>
            <Button maxWidth="Infinity" onAction="#showAddItem" style="-fx-background-color: #87cefa; box-border-color: #a9a9a9; tex-text-fill: bold;" text="Thêm sản phẩm" textFill="WHITE" />
            <Button maxWidth="Infinity" onAction="#showCreateAuction" style="-fx-background-color: #2196F3; -ox-border-color: #a9a9a9; tex-text-fill: blod;" text="Tạo phiên đấu giá" textFill="WHITE" />
            <Region VBox.vgrow="ALWAYS" />
         <ToolBar prefHeight="38.0" prefWidth="111.0" style="-fx-background-color: #f0f8ff;">
           <items>
                  <Button maxWidth="Infinity" onAction="#handleLogout" prefHeight="26.0" prefWidth="77.0" style="-fx-background-color: #0000ff;" text="Đăng xuất" textFill="WHITE" />
           </items>
         </ToolBar>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea" prefHeight="351.0" prefWidth="450.0" style="-fx-padding: 20; box-border-radius: 12;" />
    </center>
</BorderPane>
