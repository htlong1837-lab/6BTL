<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.CreateAuctionController"
      style="-fx-padding: 28; -fx-spacing: 18; -fx-background-color: #f1f5f9;">

    <!-- Header -->
    <VBox style="-fx-background-color: linear-gradient(to right, #0f172a, #1e3a5f);
                 -fx-background-radius: 12; -fx-padding: 20 24; -fx-spacing: 4;">
        <Label text="🏷 Tạo Phiên Đấu Giá Mới"
               style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: white;"/>
        <Label text="Chọn sản phẩm và thiết lập thời gian đấu giá"
               style="-fx-font-size: 12; -fx-text-fill: #94a3b8;"/>
    </VBox>

    <!-- Form card -->
    <VBox style="-fx-background-color: white; -fx-background-radius: 12;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);
                 -fx-padding: 24; -fx-spacing: 16;">
        <VBox spacing="6">
            <Label text="Sản phẩm của bạn"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <ComboBox fx:id="itemCombo" maxWidth="Infinity" prefHeight="42"
                promptText="Chọn sản phẩm muốn đấu giá..."
                style="-fx-background-radius: 8; -fx-border-radius: 8;
                       -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                       -fx-padding: 4 10; -fx-font-size: 13; -fx-background-color: #f8fafc;"/>
        </VBox>
        <VBox spacing="6">
            <Label text="Thời gian đấu giá (giờ)"
                   style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <TextField fx:id="durationField" prefHeight="42" maxWidth="Infinity"
                promptText="Ví dụ: 24"
                style="-fx-background-radius: 8; -fx-border-radius: 8;
                       -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                       -fx-padding: 10 14; -fx-font-size: 13; -fx-background-color: #f8fafc;"/>
        </VBox>
        <Button text="🚀 MỞ PHIÊN ĐẤU GIÁ" onAction="#handleCreate" maxWidth="Infinity" prefHeight="46"
                style="-fx-background-color: linear-gradient(to right, #d97706, #f59e0b);
                       -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: bold;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>
        <Label fx:id="messageLabel" wrapText="true"
               style="-fx-font-size: 12; -fx-text-fill: #16a34a; -fx-padding: 0 4;"/>
    </VBox>
</VBox>
