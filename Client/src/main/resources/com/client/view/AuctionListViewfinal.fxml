<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.Font?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.AuctionListController"
            style="-fx-background-color: #f1f5f9;">

    <!-- SIDEBAR -->
    <left>
        <VBox style="-fx-background-color: #0f172a;
                     -fx-padding: 0; -fx-spacing: 0;"
              prefWidth="210">

            <!-- Logo area -->
            <VBox style="-fx-padding: 28 20 24 20; -fx-spacing: 4;
                         -fx-background-color: #1e293b;">
                <Label text="⚡ ĐẤU GIÁ"
                       style="-fx-font-size: 16; -fx-font-weight: bold;
                              -fx-text-fill: #f59e0b; -fx-letter-spacing: 1;"/>
                <Label fx:id="usernameLabel"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #f8fafc;"/>
                <Label fx:id="balanceLabel"
                       style="-fx-font-size: 11; -fx-text-fill: #22c55e;
                              -fx-background-color: #14532d; -fx-background-radius: 20;
                              -fx-padding: 2 8;"/>
            </VBox>

            <Separator style="-fx-background-color: #334155;"/>

            <!-- Nav -->
            <VBox style="-fx-padding: 16 12; -fx-spacing: 6;" VBox.vgrow="ALWAYS">
                <Label text="MENU" style="-fx-font-size: 10; -fx-text-fill: #64748b;
                                         -fx-padding: 4 8 8 8; -fx-letter-spacing: 1;"/>
                <Button text="🏷  Phiên đấu giá" onAction="#showAuctions" maxWidth="Infinity"
                        prefHeight="40"
                        style="-fx-background-color: #2563eb;
                               -fx-text-fill: white; -fx-font-size: 13; -fx-font-weight: bold;
                               -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                               -fx-padding: 0 16; -fx-cursor: hand;"/>
                <Button text="💳  Ví của tôi" onAction="#showWallet" maxWidth="Infinity"
                        prefHeight="40"
                        style="-fx-background-color: transparent;
                               -fx-text-fill: #94a3b8; -fx-font-size: 13;
                               -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                               -fx-padding: 0 16; -fx-cursor: hand;"/>
                <Region VBox.vgrow="ALWAYS"/>
                <Separator style="-fx-background-color: #334155;"/>
                <Button text="🚪  Đăng xuất" onAction="#handleLogout" maxWidth="Infinity"
                        prefHeight="40"
                        style="-fx-background-color: #7f1d1d;
                               -fx-text-fill: #fca5a5; -fx-font-size: 13;
                               -fx-background-radius: 8; -fx-alignment: CENTER_LEFT;
                               -fx-padding: 0 16; -fx-cursor: hand;"/>
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <VBox style="-fx-padding: 28; -fx-spacing: 16; -fx-background-color: #f1f5f9;">

            <!-- Header bar -->
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: white; -fx-padding: 18 24;
                         -fx-background-radius: 12;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);">
                <VBox spacing="2">
                    <Label text="Phiên Đấu Giá Đang Mở"
                           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                    <Label text="Theo dõi và tham gia các phiên đấu giá"
                           style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>
                </VBox>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="⟳  Làm mới" onAction="#loadAuctions"
                        prefHeight="38" prefWidth="110"
                        style="-fx-background-color: #f1f5f9;
                               -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-text-fill: #374151; -fx-font-size: 13; -fx-cursor: hand;"/>
            </HBox>

            <!-- Table -->
            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white;
                              -fx-background-radius: 12;
                              -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 8, 0, 0, 2);
                              -fx-table-cell-border-color: #f1f5f9;
                              -fx-border-color: transparent;">
                <columns>
                    <TableColumn fx:id="colName"   text="Sản Phẩm"      prefWidth="220"/>
                    <TableColumn fx:id="colPrice"  text="Giá Hiện Tại"  prefWidth="140"/>
                    <TableColumn fx:id="colLeader" text="Người Dẫn Đầu" prefWidth="160"/>
                    <TableColumn fx:id="colStatus" text="Trạng Thái"    prefWidth="110"/>
                    <TableColumn fx:id="colAction" text="Thao Tác"      prefWidth="120"/>
                </columns>
            </TableView>

            <Label fx:id="statusLabel"
                   style="-fx-font-size: 12; -fx-text-fill: #64748b; -fx-padding: 0 4;"/>
        </VBox>
    </center>
</BorderPane>
