<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.controller.WalletController"
      style="-fx-padding: 32; -fx-spacing: 20; -fx-background-color: #f1f5f9;"
      alignment="TOP_CENTER">

    <VBox style="-fx-background-color: white; -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);
                 -fx-padding: 36; -fx-spacing: 16; -fx-alignment: CENTER;"
          maxWidth="420">
        <Label text="💳 Ví Của Tôi"
               style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        <Separator/>
        <VBox style="-fx-background-color: linear-gradient(to right, #0f172a, #1e3a5f);
                     -fx-background-radius: 12; -fx-padding: 24; -fx-spacing: 8; -fx-alignment: CENTER;"
              maxWidth="360">
            <Label text="SỐ DƯ HIỆN TẠI"
                   style="-fx-font-size: 11; -fx-text-fill: #94a3b8; -fx-letter-spacing: 1;"/>
            <Label fx:id="balanceLabel"
                   style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
        </VBox>
    </VBox>

    <VBox style="-fx-background-color: white; -fx-background-radius: 16;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 3);
                 -fx-padding: 28; -fx-spacing: 12;"
          maxWidth="420">

        <Label text="Nạp tiền vào ví"
               style="-fx-font-size: 15; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
        <Separator/>

        <TextField fx:id="amountField"
                   promptText="Nhập số tiền (VND)"
                   style="-fx-font-size: 14; -fx-padding: 10; -fx-background-radius: 8;"/>

        <Button text="Nạp tiền" onAction="#handleDeposit"
                maxWidth="Infinity"
                style="-fx-background-color: #2563eb; -fx-text-fill: white;
                       -fx-font-size: 14; -fx-font-weight: bold;
                       -fx-padding: 10; -fx-background-radius: 8; -fx-cursor: hand;"/>

        <Label fx:id="messageLabel" text=""
               style="-fx-font-size: 13;"/>
    </VBox>
</VBox>
