<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<ScrollPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.ProductFormController"
            fitToWidth="true">
<VBox style="-fx-padding: 20; -fx-spacing: 12; -fx-background-color: white;">

    <Label text="Thêm sản phẩm mới" style="-fx-font-size: 16; -fx-font-weight: bold;"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Tên sản phẩm:" prefWidth="140"/>
        <TextField fx:id="nameField"  promptText="Tên sản phẩm" HBox.hgrow="ALWAYS"/>
    </HBox>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Mô tả:" prefWidth="140"/>
        <TextArea fx:id="descField"   promptText="Mô tả chi tiết" prefRowCount="3" HBox.hgrow="ALWAYS"/>
    </HBox>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Giá khởi điểm:" prefWidth="140"/>
        <TextField fx:id="priceField" promptText="VD: 5000000"   HBox.hgrow="ALWAYS"/>
    </HBox>
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Loại sản phẩm:" prefWidth="140"/>
        <ComboBox fx:id="categoryCombo" onAction="#onCategoryChanged"
                  maxWidth="Infinity" HBox.hgrow="ALWAYS" promptText="Chọn loại..."/>
    </HBox>

    <!-- === ART === -->
    <VBox fx:id="artFields" spacing="10" managed="false" visible="false">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Họa sĩ:" prefWidth="140"/>
            <TextField fx:id="artistField" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Chất liệu:" prefWidth="140"/>
            <TextField fx:id="mediumField" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- === VEHICLE === -->
    <VBox fx:id="vehicleFields" spacing="10" managed="false" visible="false">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Hãng xe:" prefWidth="140"/>
            <TextField fx:id="makeField"  HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Dòng xe:" prefWidth="140"/>
            <TextField fx:id="modelField" HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Năm sản xuất:" prefWidth="140"/>
            <TextField fx:id="yearField"  HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <!-- === ELECTRONICS === -->
    <VBox fx:id="electronicsFields" spacing="10" managed="false" visible="false">
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Thương hiệu:" prefWidth="140"/>
            <TextField fx:id="brandField"    HBox.hgrow="ALWAYS"/>
        </HBox>
        <HBox spacing="10" alignment="CENTER_LEFT">
            <Label text="Bảo hành (tháng):" prefWidth="140"/>
            <TextField fx:id="warrantyField" HBox.hgrow="ALWAYS"/>
        </HBox>
    </VBox>

    <Button text="Thêm sản phẩm" onAction="#handleSubmit" maxWidth="Infinity"
            style=" -fx-text-fill: white; -fx-font-size: 14;"/>
    <Label fx:id="messageLabel" wrapText="true"/>
</VBox>
</ScrollPane>
