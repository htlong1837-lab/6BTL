<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
            prefHeight="480.0" prefWidth="900.0"
            style="-fx-background-color: linear-gradient(to bottom right, #0f172a, #1e3a5f);"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.LoginController">
   <children>

      <!-- Left branding panel -->
      <VBox alignment="CENTER" spacing="16"
            AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
            AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="480">
         <Label text="⚡" style="-fx-font-size: 48; -fx-text-fill: #f59e0b;"/>
         <Label text="HỆ THỐNG ĐẤU GIÁ"
                style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: white; -fx-letter-spacing: 2;"/>
         <Label text="Nền tảng đấu giá trực tuyến\nuy tín &amp; chuyên nghiệp"
                style="-fx-font-size: 13; -fx-text-fill: #94a3b8; -fx-text-alignment: center;"
                textAlignment="CENTER" wrapText="true"/>
         <Region prefHeight="20"/>
         <Label text="● An toàn  ● Minh bạch  ● Tin cậy"
                style="-fx-font-size: 11; -fx-text-fill: #f59e0b;"/>
      </VBox>

      <!-- Right login form -->
      <VBox fx:id="loginBox" alignment="CENTER" spacing="14"
            AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
            AnchorPane.rightAnchor="0" AnchorPane.leftAnchor="420"
            style="-fx-background-color: white; -fx-padding: 50 50 50 50;">

         <Label text="Đăng nhập" style="-fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #0f172a;">
            <font><Font name="System Bold" size="26"/></font>
         </Label>
         <Label text="Chào mừng bạn trở lại 👋"
                style="-fx-font-size: 13; -fx-text-fill: #64748b;"/>

         <Region prefHeight="8"/>

         <VBox spacing="4" maxWidth="340">
            <Label text="Tên đăng nhập" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <TextField fx:id="userNameField" maxWidth="340" prefHeight="42"
               promptText="Nhập tên đăng nhập"
               style="-fx-background-radius: 8; -fx-border-radius: 8;
                      -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                      -fx-padding: 10 14; -fx-font-size: 13;
                      -fx-background-color: #f8fafc;"/>
         </VBox>

         <VBox spacing="4" maxWidth="340">
            <Label text="Mật khẩu" style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <PasswordField fx:id="passwordField" maxWidth="340" prefHeight="42"
               promptText="Nhập mật khẩu"
               style="-fx-background-radius: 8; -fx-border-radius: 8;
                      -fx-border-color: #e2e8f0; -fx-border-width: 1.5;
                      -fx-padding: 10 14; -fx-font-size: 13;
                      -fx-background-color: #f8fafc;"/>
         </VBox>

         <Label fx:id="errorLabel"
            text="Tài khoản hoặc mật khẩu chưa chính xác"
            style="-fx-text-fill: #dc2626; -fx-font-size: 12; -fx-background-color: #fef2f2;
                   -fx-background-radius: 6; -fx-padding: 8 12;"
            visible="false" maxWidth="340"/>

         <Button onAction="#handleLogin"
            mnemonicParsing="false"
            prefHeight="44" maxWidth="340"
            style="-fx-background-color: linear-gradient(to right, #1e3a5f, #2563eb);
                   -fx-text-fill: white; -fx-background-radius: 8;
                   -fx-font-size: 14; -fx-font-weight: bold; -fx-cursor: hand;"
            text="ĐĂNG NHẬP →"/>

         <Label text="Chưa có tài khoản? Đăng ký ngay"
            style="-fx-text-fill: #2563eb; -fx-cursor: hand; -fx-font-size: 13;"
            onMouseClicked="#goToRegister"/>
      </VBox>

   </children>
</AnchorPane>
