<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.controller.AuctionListController"
            >

    <!-- SIDEBAR -->
    <left>
        <VBox style=" -fx-padding: 20; -fx-spacing: 8;" prefWidth="190">
            <Label fx:id="usernameLabel" style=" -fx-font-size: 13; -fx-font-weight: bold;"/>
            <Label fx:id="balanceLabel"  style=" -fx-font-size: 11;"/>
            <Separator/>
            <Button text="Phiên đấu giá"  onAction="#showAuctions"  maxWidth="Infinity"
                    style=" -fx-text-fill: white;"/>
            <Button text="Ví của tôi"     onAction="#showWallet"    maxWidth="Infinity"
                    style="-fx-background-color: transparent; "/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Đăng xuất"      onAction="#handleLogout"  maxWidth="Infinity"
                    style=" -fx-text-fill: white;"/>
        </VBox>
    </left>

    <!-- NỘI DUNG CHÍNH -->
    <center>
        <VBox style="-fx-padding: 20; -fx-spacing: 10;">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="Phiên đấu giá đang mở" style="-fx-font-size: 18; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Làm mới" onAction="#loadAuctions"/>
            </HBox>
            <TableView fx:id="auctionTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colName"    text="Sản phẩm"      prefWidth="210"/>
                    <TableColumn fx:id="colPrice"   text="Giá hiện tại"  prefWidth="130"/>
                    <TableColumn fx:id="colLeader"  text="Người dẫn đầu" prefWidth="150"/>
                    <TableColumn fx:id="colStatus"  text="Trạng thái"    prefWidth="100"/>
                    <TableColumn fx:id="colAction"  text="Thao tác"      prefWidth="110"/>
                </columns>
            </TableView>
            <Label fx:id="statusLabel" />
        </VBox>
    </center>
</BorderPane>
